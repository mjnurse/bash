lld() {
   ls -ld ${*:-*} | sed '/^[^d]/d; s/^[^ ]*  *[0-9]*  *[^ ]*  *[^ ]*  *[^ ]*  *[^ ]*  *[^ ]*  *[^ ]*  *//'
}

lmr() {
    if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        echo "Usage: lmr [-n <number>] <pattern> - List most recently modified files matching pattern"
        return 1
    fi
    if [[ "$1" == "-n" ]]; then
        shift
        n="$1"
        shift
    else
        n=10
    fi
    find . -type f -printf '%T@ %TY/%Tm/%Td %TH:%TM:%.2TS %p\n' | sort -rn | head -"$n" | cut -d' ' -f2-
}

# Custom trash function that moves files to ~/.trash instead of deleting them
trash() {
    mkdir -p ~/.trash

    if [[ "$1" == "" ]]; then
        echo -e "\e[92m20 largest:\e[39m"
        ls -alhS ~/.trash | grep -v '^\(total\|.*[[:space:]]\.\.\?$\)' | head -20
        echo -e "\e[92m20 most recent:\e[39m"
        ls -alht ~/.trash | grep -v '^\(total\|.*[[:space:]]\.\.\?$\)' | head -20
        echo -e "\e[92mSize:\e[39m $(du -d0 -h ~/.trash 2>/dev/null)"
        echo -e "\e[92mOptions:\e[39m"
        echo "-f|--force (force delete without confirmation)"
        echo "-i|--interactive (prompt before deleting each file)"
        echo "-p|--purge <filename (or leading characters)> (delete file from trash)"
    fi
    force_yn=n

    # Parse -p option
    if [[ "$1" == "-p" || "$1" == "--purge" ]]; then
        shift
        ls -alh "/home/martin/.trash/$1"* 2>/dev/null
        [[ $? -ne 0 ]] && { echo "No matching files found in trash for $1*"; return; }
        read -p "Purge these files? [yN] " answer
        [[ "${answer^^}" == "Y" ]] || { echo "Purge cancelled"; return; }
        \rm "/home/martin/.trash/$1"*
        return 1
    fi

    # Parse -f option
    if [[ "$1" == "-f" || "$1" == "--force" ]]; then
        force_yn=y
        shift
    fi

    # Parse -i option
    if [[ "$1" == "-i" || "$1" == "--interactive" ]]; then
        force_yn=n
        shift
    fi

    for f in "$@"; do
        if [ ! -e "$f" ]; then
            echo "trash: '$f' not found"
            continue
        fi

        if [[ $force_yn == n ]]; then
            read -p "trash: Are you sure you want to delete '$f' [yN] " answer
            [[ "${answer^^}" == "Y" ]] || { echo "Skipped '$f'"; continue; }
        fi

        timestamp=$(date +%Y%m%d_%H%M%S)
        base=$(basename "$f")
        dest=~/.trash/"$base.$timestamp"
        mv "$f" "$dest"
        if [[ -d $dest ]]; then
            tar -czf "$dest.tar.gz" "$dest" > /tmp/trash.log 2>&1
            \rm -rf "$dest"
        else
	        gzip "$dest" > /tmp/trash.log 2>&1
        fi
    done
}

# Custom goto function that uses the 'goto' command and evaluates the result
g () {
    goto -s "$1"
    eval "$(goto -r)"
}

# Custom function to open MarkText with GPU disabled and no sandbox, suppressing output
md() {
    marktext --disable-gpu --no-sandbox $1 > /dev/null 2>&1 &
}

# Custom functions for find with case-insensitive search
f() {
    if [[ "$1" == "" ]]; then
        echo "Usage: f <filename> - Search for a file with case-insensitive name"
        return 1
    fi
    args=()
    for f in "$@"; do
        args+=(-o -iname "$f")
    done
    find -type d -name ".?*" -prune \
      -o -type d -name venv -prune \
      -o -type d -name google-cloud-sdk -prune \
      -o -type d -name pkg -prune \
      "${args[@]}" -print | sort
}

c() {
    model=sonnet
    if [[ "$1" == "" ]]; then
        echo "Note - can use: c \"<question for Claude>\""
        echo
        echo "Select model:"
        echo "h - Haiku (fast)"
        echo "s - Sonnet (general)"
        echo "o - Opus (coding)"
        echo
        read -p "> " m
    fi
    if [[ "$*" == "h" || "$*" == "s" || "$*" == "o" ]]; then
        m="$*"
        shift
    fi
    case $m in
        h)  model=haiku ;;
        s)  model=sonnet ;;
        o)  model=opus ;;
        *)  [[ "$m" != "" ]] && echo "Invalid selection: $m"; return ;;
    esac
    question="$*"
    if [[ "$question" == "" ]]; then
        claude --model $model
    else
        claude --model $model --print "$question"
    fi
}


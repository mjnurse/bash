#!/usr/bin/env bash
help_text="
NAME
   mjnfind - Finds files a set of commonly used directories

USAGE
   mjnfind [options] <parameters>

OPTIONS
   -a
      Extend search to the entire C drive.

DESCRIPTION
   Finds files a set of commonly used directories.

AUTHOR
  mjnurse.uk 2020
"
help_line="Finds files in commonly used directories"
web_desc="Finds files in commonly used directories"

TMP1="/tmp/mjnfind1.tmp"
TMP2="/tmp/mjnfind2.tmp"

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
   echo "$help_text"
   exit 0
fi

if [[ "$1" == "-a" ]]; then
   start_dirs="/c"
   shift
else
   start_dirs="/home/martin/mjnurse xxx yyy"
fi

\rm -f $TMP1 $TMP2

for d in $start_dirs; do
    if [[ -d "$d" ]]; then
        echo "Searching in: $d"
        find "$d" -type d -name ".*" -prune -false -o -type f -iname "$1" -ls 2>/dev/null >> $TMP1
    fi
done

if [[ ! -s $TMP1 ]]; then
   echo "No files found matching: $1"
   \rm -f $TMP1 $TMP2
   exit 0
fi

i=1
for f in $(cat $TMP1); do
   if [[ "$f" == *"/"* ]]; then
      filepath=$f
      echo "$i $filepath" >> $TMP2
      i=$((i+1))
   fi
done
cat $TMP2
read -p "Enter c-code v-gvim and file Num To Edit (RTN to cancel) [Cv]#: " fn
if [[ -n $fn ]]; then
    filepath=$(sed "${fn:1:99}q; d" $TMP2 | sed "s/^[0-9 ]*//")
    if [[ -n "$filepath" ]]; then
        if [[ "${fn:0:1}" == "v" ]]; then
            gvim "$filepath"
        else
            code "$filepath"
        fi
    fi
fi

\rm -f $TMP1 $TMP2